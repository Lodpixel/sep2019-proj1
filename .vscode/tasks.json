{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake Configure (Qt MinGW Debug)",
      "type": "shell",
      "command": "C:/Qt/Tools/CMake_64/bin/cmake.exe",
      "args": [
        "-S",
        "${workspaceFolder}",
        "-B",
        "${workspaceFolder}/build/Desktop_Qt_6_10_2_MinGW_64_bit-Debug",
        "-G",
        "MinGW Makefiles",
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
        "-DCMAKE_PREFIX_PATH=C:/Qt/6.10.2/mingw_64",
        "-DCMAKE_C_COMPILER=C:/Qt/Tools/mingw1310_64/bin/gcc.exe",
        "-DCMAKE_CXX_COMPILER=C:/Qt/Tools/mingw1310_64/bin/g++.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:/Qt/6.10.2/mingw_64/bin;C:/Qt/Tools/mingw1310_64/bin;${env:PATH}"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "CMake Build (Qt MinGW Debug)",
      "type": "shell",
      "command": "C:/Qt/Tools/CMake_64/bin/cmake.exe",
      "args": [
        "--build",
        "${workspaceFolder}/build/Desktop_Qt_6_10_2_MinGW_64_bit-Debug",
        "-j",
        "4"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:/Qt/6.10.2/mingw_64/bin;C:/Qt/Tools/mingw1310_64/bin;${env:PATH}"
        }
      },
      "problemMatcher": [
        "$gcc"
      ],
      "dependsOn": "CMake Configure (Qt MinGW Debug)",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Run sep2019-proj1 (Debug)",
      "type": "shell",
      "command": "${workspaceFolder}/build/Desktop_Qt_6_10_2_MinGW_64_bit-Debug/sep2019-proj1.exe",
      "options": {
        "cwd": "${workspaceFolder}/build/Desktop_Qt_6_10_2_MinGW_64_bit-Debug",
        "env": {
          "PATH": "C:/Qt/6.10.2/mingw_64/bin;C:/Qt/Tools/mingw1310_64/bin;${env:PATH}"
        }
      },
      "dependsOn": "CMake Build (Qt MinGW Debug)",
      "problemMatcher": []
    }
  ]
}
