{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug sep2019-proj1 (Qt MinGW)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/Desktop_Qt_6_10_2_MinGW_64_bit-Debug/sep2019-proj1.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/build/Desktop_Qt_6_10_2_MinGW_64_bit-Debug",
      "environment": [
        {
          "name": "PATH",
          "value": "C:/Qt/6.10.2/mingw_64/bin;C:/Qt/Tools/mingw1310_64/bin;${env:PATH}"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/Qt/Tools/mingw1310_64/bin/gdb.exe",
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "CMake Build (Qt MinGW Debug)"
    }
  ]
}
